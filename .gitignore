# ============================================================
# ATS Resume Scorer — .gitignore
# ============================================================

# ----------------------------
# Environment & Secrets
# ----------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# ----------------------------
# Python
# ----------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/
.installed.cfg
MANIFEST

# ----------------------------
# Virtual Environments
# ----------------------------
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/


# ----------------------------
# Dependency Managers
# ----------------------------
pip-log.txt
pip-delete-this-directory.txt
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytestdebug.log

# ----------------------------
# FastAPI / Uvicorn
# ----------------------------
*.log
logs/
*.sqlite3
*.db

# ----------------------------
# Streamlit
# ----------------------------
.streamlit/secrets.toml
frontend/.streamlit/secrets.toml

# ----------------------------
# Jupyter Notebooks
# ----------------------------
.ipynb_checkpoints/
*/.ipynb_checkpoints/
jupyter notebooks/.ipynb_checkpoints/
jupyterNotebook/.ipynb_checkpoints/
# Keep notebooks but ignore outputs (optional — remove next line to track outputs)
# *.ipynb   # uncomment to ignore notebooks entirely

# ----------------------------
# IDE & Editors
# ----------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# ----------------------------
# OS Generated
# ----------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ----------------------------
# Uploads & Temp Files
# ----------------------------
uploads/
tmp/
temp/
*.tmp
*.bak
*.orig

# ----------------------------
# ML / Data
# ----------------------------
*.pkl
*.pickle
*.h5
*.hdf5
*.pt
*.pth
*.ckpt
data/raw/
data/processed/
datasets/

# ----------------------------
# Docker
# ----------------------------
.dockerenv
docker-compose.override.yml

# ----------------------------
# Misc
# ----------------------------
*.zip
*.tar.gz
*.rar
